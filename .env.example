# 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ===== AI 服务配置=====
# AI 服务域名，默认为 wecutplat.ai
VITE_AI_DOMAIN=wecutplat.ai

# AI 模型名称，默认为 default#wecutplat-chat
VITE_AI_MODEL=default#wecutplat-chat

# 平台名称，用于显示，默认为 WeCutPlat
VITE_PLATFORM_NAME=WeCutPlat

# ===== 功能开关配置 =====
# AI Chat 功能开关（替代 ECO_FEATURE_WEGENT_CHAT）
ECO_FEATURE_AI_CHAT=true
